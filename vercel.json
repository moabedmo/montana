{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/shop", "destination": "/shop.html" },
    { "source": "/cart", "destination": "/cart.html" },
    { "source": "/checkout", "destination": "/checkout.html" },
    { "source": "/product", "destination": "/product.html" },
    { "source": "/ingredients", "destination": "/ingredients.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/privacy-policy", "destination": "/privacy-policy.html" },
    { "source": "/order-success", "destination": "/order-success.html" },
    { "source": "/api/settings/chat", "destination": "/api/settings/chat.js" },
    { "source": "/api/chat/ai", "destination": "/api/chat/ai.js" },
    { "source": "/api/chat/gemini", "destination": "/api/chat/gemini.js" },
    { "source": "/api/settings/gemini", "destination": "/api/settings/gemini.js" },
    { "source": "/api/settings/social", "destination": "/api/settings/social.js" },
    { "source": "/api/settings/shipping", "destination": "/api/settings/shipping.js" },
    { "source": "/api/shipping/calculate", "destination": "/api/shipping/calculate.js" },
    { "source": "/api/shipping/create", "destination": "/api/shipping/create.js" },
    { "source": "/api/shipping/track", "destination": "/api/shipping/track.js" },
    { "source": "/api/webhooks/meta", "destination": "/api/webhooks/meta.js" },
    { "source": "/api/messages/social", "destination": "/api/messages/social.js" },
    { "source": "/api/telegram/send", "destination": "/api/telegram/send.js" },
    { "source": "/api/cron/refresh-tokens", "destination": "/api/cron/refresh-tokens.js" }
  ],
  "crons": [
    {
      "path": "/api/cron/refresh-tokens",
      "schedule": "0 6 * * *"
    }
  ]
}
