{
  "version": 2,
  "routes": [
    { "handle": "filesystem" },

    { "src": "^/api/settings/chat$", "dest": "/api/settings/chat.js" },
    { "src": "^/api/chat/ai$", "dest": "/api/chat/ai.js" },
    { "src": "^/api/chat/gemini$", "dest": "/api/chat/gemini.js" },
    { "src": "^/api/settings/gemini$", "dest": "/api/settings/gemini.js" },
    { "src": "^/api/settings/social$", "dest": "/api/settings/social.js" },
    { "src": "^/api/settings/shipping$", "dest": "/api/settings/shipping.js" },
    { "src": "^/api/shipping/calculate$", "dest": "/api/shipping/calculate.js" },
    { "src": "^/api/shipping/create$", "dest": "/api/shipping/create.js" },
    { "src": "^/api/shipping/track$", "dest": "/api/shipping/track.js" },
    { "src": "^/api/webhooks/meta$", "dest": "/api/webhooks/meta.js" },
    { "src": "^/api/messages/social$", "dest": "/api/messages/social.js" },
    { "src": "^/api/telegram/send$", "dest": "/api/telegram/send.js" },
    { "src": "^/api/cron/refresh-tokens$", "dest": "/api/cron/refresh-tokens.js" },

    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/admin/?$", "dest": "/admin/index.html" },
    { "src": "^/shop/?$", "dest": "/shop.html" },
    { "src": "^/cart/?$", "dest": "/cart.html" },
    { "src": "^/checkout/?$", "dest": "/checkout.html" },
    { "src": "^/product/?$", "dest": "/product.html" },
    { "src": "^/ingredients/?$", "dest": "/ingredients.html" },
    { "src": "^/privacy/?$", "dest": "/privacy.html" },
    { "src": "^/privacy-policy/?$", "dest": "/privacy-policy.html" },
    { "src": "^/order-success/?$", "dest": "/order-success.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/refresh-tokens",
      "schedule": "0 6 * * *"
    }
  ]
}
