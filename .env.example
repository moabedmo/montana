# Gemini (chatbot — recommended: vision + Arabic)
GEMINI_API_KEY=

# gemini | groq (default gemini)
CHAT_PROVIDER=gemini

# gemini-2.0-flash = default (smart + vision) | gemini-2.0-flash-lite = cheaper
# GEMINI_MODEL=gemini-2.0-flash

# Groq (optional fallback)
GROQ_API_KEY=

# true = AI first, local brains for orders/catalog | false = local only
CHAT_USE_AI=true

# Supabase (required — deposit approvals, social, shipping)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# After adding keys, run migrations 001 + 002 + 003 in Supabase SQL Editor
# Test: GET /api/settings/supabase

# Admin API protection (optional — one-click deposit approve link in Telegram)
MONTANA_ADMIN_API_KEY=your-secret-admin-key

# Site URL for approve links in Telegram (optional — Vercel sets VERCEL_URL automatically)
SITE_URL=https://montana-eta.vercel.app

# Meta App credentials (required for long-lived token exchange)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# Meta webhook verification (set same value in Meta App Dashboard)
META_WEBHOOK_VERIFY_TOKEN=montana_meta_verify

# Meta Graph API version (optional)
META_GRAPH_VERSION=v21.0

# Token refresh job
TOKEN_REFRESH_BEFORE_DAYS=7
TOKEN_REFRESH_INTERVAL_MS=86400000
CRON_SECRET=your-cron-secret

# Server port (local dev)
PORT=3000

# Telegram — deposit proof + order notifications (required for deposit flow)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=https://montana-eta.vercel.app/api/webhooks/telegram

# Admin approval words on Telegram (comma-separated)
DEPOSIT_APPROVAL_WORDS=تم,تمام,ok,yes,approve,موافق,تأكيد

# Deposit before order confirm (EGP)
ORDER_DEPOSIT_AMOUNT=200
DEPOSIT_PAYMENT_INFO_AR=حوّلي 200 جنيه عربون على [رقم المحفظة] — وارفعي صورة التحويل قبل تأكيد الأوردر.
DEPOSIT_PAYMENT_INFO_EN=Transfer 200 EGP deposit to [wallet number] — upload proof before confirming your order.
