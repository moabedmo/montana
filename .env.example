# Gemini (chatbot — recommended: vision + Arabic)
GEMINI_API_KEY=

# gemini | groq (default gemini)
CHAT_PROVIDER=gemini

# gemini-2.0-flash = default (smart + vision) | gemini-2.0-flash-lite = cheaper
# GEMINI_MODEL=gemini-2.0-flash

# Groq (optional fallback)
GROQ_API_KEY=

# true = AI first, local brains for orders/catalog | false = local only
CHAT_USE_AI=true

# Supabase (required for social settings API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin API protection (optional — if unset, API is open in dev)
MONTANA_ADMIN_API_KEY=your-secret-admin-key

# Meta App credentials (required for long-lived token exchange)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# Meta webhook verification (set same value in Meta App Dashboard)
META_WEBHOOK_VERIFY_TOKEN=montana_meta_verify

# Meta Graph API version (optional)
META_GRAPH_VERSION=v21.0

# Token refresh job
TOKEN_REFRESH_BEFORE_DAYS=7
TOKEN_REFRESH_INTERVAL_MS=86400000
CRON_SECRET=your-cron-secret

# Server port (local dev)
PORT=3000
